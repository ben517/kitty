# SmartThings API
SOS_SMARTTHINGS_TOKEN=your_pat_token_here
SOS_SMARTTHINGS_LOCATION_ID=your_location_id

# LLM Configuration (via litellm, uses OpenAI-compatible format)
# For DashScope: model=openai/qwen-turbo, base_url=https://dashscope.aliyuncs.com/compatible-mode/v1
SOS_LLM_MODEL=openai/qwen-turbo
SOS_LLM_API_KEY=your_dashscope_api_key
SOS_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding Configuration
SOS_EMBEDDING_MODEL=openai/text-embedding-v3
SOS_EMBEDDING_API_KEY=your_dashscope_api_key
SOS_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ChromaDB
SOS_CHROMA_PERSIST_DIR=./data/chroma
SOS_CHROMA_COLLECTION_NAME=device_knowledge

# RAG
SOS_RAG_TOP_K=5
SOS_RAG_RERANK_TOP_N=3
SOS_RAG_CHUNK_SIZE=500
SOS_RAG_CHUNK_OVERLAP=50
