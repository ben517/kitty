# SmartThings API
SMARTTHINGS_TOKEN=your_pat_token_here
SMARTTHINGS_LOCATION_ID=your_location_id

# LLM Configuration (via litellm, uses OpenAI-compatible format)
# For DashScope: model=openai/qwen-turbo, base_url=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=openai/qwen-turbo
LLM_API_KEY=your_dashscope_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embedding Configuration
EMBEDDING_MODEL=openai/text-embedding-v3
EMBEDDING_API_KEY=your_dashscope_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=device_knowledge

# RAG
RAG_TOP_K=5
RAG_RERANK_TOP_N=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
